<Window
    x:Class="BabelStudio.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:BabelStudio.App.ViewModels"
    mc:Ignorable="d"
    Title="Babel Studio">

    <Grid Padding="20" RowSpacing="16" ColumnSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="420" />
        </Grid.ColumnDefinitions>

        <!-- Row 0: Toolbar -->
        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12">
            <Button Content="Open Media" Click="OpenMediaButton_Click" />
            <Button Content="Open Project" Click="OpenProjectButton_Click" />
            <Button Content="Save Transcript" Click="SaveTranscriptButton_Click" IsEnabled="{x:Bind ViewModel.CanSaveTranscript, Mode=OneWay}" />
            <Button Content="{x:Bind ViewModel.TranslateButtonText, Mode=OneWay}"
                    Click="TranslateButton_Click"
                    IsEnabled="{x:Bind ViewModel.CanTranslate, Mode=OneWay}" />
            <Button Content="Save Translation"
                    Click="SaveTranslationButton_Click"
                    IsEnabled="{x:Bind ViewModel.CanSaveTranslation, Mode=OneWay}" />
            <Button Content="Merge Selected" Click="MergeSegmentsButton_Click" />
            <Button Content="Save Settings" Click="SaveSettingsButton_Click" />
        </StackPanel>

        <!--
            Row 1, Col 0: Left panel.
            Uses a nested two-row Grid so the video/controls/waveform area is Auto-height
            and the segments list below it gets all remaining space (*), giving the ListView
            a finite, bounded height so its built-in scroll container activates.
        -->
        <Grid Grid.Row="1" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Video player, playback controls, warning, waveform -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="12">
                    <Grid>
                        <MediaPlayerElement x:Name="SourcePlayerElement"
                                            AreTransportControlsEnabled="False"
                                            Height="320" />
                        <Border VerticalAlignment="Bottom"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,20"
                                Padding="16,8"
                                Background="#90000000"
                                CornerRadius="8">
                            <TextBlock FontSize="20"
                                       Foreground="White"
                                       Text="{x:Bind ViewModel.CurrentSubtitleText, Mode=OneWay}"
                                       TextAlignment="Center"
                                       TextWrapping="WrapWholeWords" />
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
                    <Button Content="Play" Click="PlayButton_Click" IsEnabled="{x:Bind ViewModel.CanPlayMedia, Mode=OneWay}" />
                    <Button Content="Pause" Click="PauseButton_Click" IsEnabled="{x:Bind ViewModel.CanPlayMedia, Mode=OneWay}" />
                    <Button Content="Jump to Active" Click="JumpToActiveSegmentButton_Click" />
                    <TextBlock VerticalAlignment="Center" Text="{x:Bind ViewModel.PlaybackPositionText, Mode=OneWay}" />
                    <TextBlock VerticalAlignment="Center" Text="Speed" />
                    <ComboBox x:Name="PlaybackSpeedComboBox"
                              Width="100"
                              ItemsSource="{x:Bind ViewModel.PlaybackSpeedOptions, Mode=OneWay}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Rate"
                              SelectedIndex="1"
                              SelectionChanged="PlaybackSpeedComboBox_SelectionChanged" />
                    <CheckBox Margin="12,0,0,0"
                              VerticalAlignment="Center"
                              Content="Target subtitles"
                              IsChecked="{x:Bind ViewModel.ShowTranslatedSubtitles, Mode=TwoWay}"
                              IsEnabled="{x:Bind ViewModel.CanShowTranslatedSubtitles, Mode=OneWay}" />
                    <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" Text="{x:Bind ViewModel.PlaybackBackendLabel, Mode=OneWay}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="6">
                    <TextBlock Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               Text="{x:Bind ViewModel.PlaybackWarning, Mode=OneWay}"
                               TextWrapping="WrapWholeWords" />
                    <canvas:CanvasControl x:Name="WaveformCanvas"
                                          Height="96"
                                          Draw="WaveformCanvas_Draw"
                                          PointerPressed="WaveformCanvas_PointerPressed" />
                </StackPanel>
            </Grid>

            <!--
                Segments area — row 1 (*) of the left-column Grid.
                This row gets all remaining vertical space after the video area above,
                so the ListView receives a finite height and can scroll.
            -->
            <Grid Grid.Row="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid RowSpacing="8" ColumnSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center" Text="Project Name" />
                    <TextBox Grid.Column="1"
                             MinWidth="280"
                             Text="{x:Bind ViewModel.ProjectNameDraft, Mode=TwoWay}" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Transcript Language" />
                    <ComboBox Grid.Column="3"
                              PlaceholderText="Choose language"
                              ItemsSource="{x:Bind ViewModel.TranscriptLanguageOptions, Mode=OneWay}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Code"
                              SelectedValue="{x:Bind ViewModel.SelectedTranscriptLanguageCode, Mode=TwoWay}"
                              SelectionChanged="TranscriptLanguageComboBox_SelectionChanged" />
                    <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="Translation Target" />
                    <ComboBox Grid.Column="5"
                              x:Name="TranslationTargetComboBox"
                              PlaceholderText="Choose target"
                              ItemsSource="{x:Bind ViewModel.SupportedTranslationTargets, Mode=OneWay}"
                              DisplayMemberPath="DisplayLabel"
                              SelectedValuePath="LanguageCode"
                              SelectedValue="{x:Bind ViewModel.SelectedTranslationTargetLanguageCode, Mode=TwoWay}"
                              SelectionChanged="TranslationTargetComboBox_SelectionChanged" />
                    <CheckBox Grid.Row="1"
                              Grid.ColumnSpan="6"
                              Content="Detect speakers during transcript import"
                              IsChecked="{x:Bind ViewModel.EnableSpeakerDiarizationOnImport, Mode=TwoWay}" />
                    <TextBlock Grid.Row="2"
                               Grid.ColumnSpan="6"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind ViewModel.TranslationTargetStatus, Mode=OneWay}"
                               TextWrapping="WrapWholeWords" />
                </Grid>

                <ListView Grid.Row="1"
                          x:Name="SegmentsListView"
                          IsItemClickEnabled="True"
                          ItemClick="SegmentsListView_ItemClick"
                          ItemsSource="{x:Bind ViewModel.Segments, Mode=OneWay}"
                          SelectionMode="Multiple">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:TranscriptSegmentItem">
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    Background="{x:Bind BackgroundBrush, Mode=OneWay}"
                                    CornerRadius="8">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock VerticalAlignment="Center" Text="{x:Bind DisplayTimeRange}" />
                                        <Button Content="Jump" Click="JumpToSegmentButton_Click" Tag="{x:Bind}" />
                                        <Button Content="Audition TTS"
                                                Click="AuditionTtsButton_Click"
                                                IsEnabled="{x:Bind CanAuditionTts, Mode=OneWay}"
                                                Tag="{x:Bind}" />
                                        <Button Content="Split at Cursor" Click="SplitSegmentButton_Click" Tag="{x:Bind}" />
                                        <Button Content="Apply Timing" Click="TrimSegmentButton_Click" Tag="{x:Bind}" />
                                        <Button Content="Delete" Click="DeleteSegmentButton_Click" Tag="{x:Bind}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border Width="12"
                                                Height="12"
                                                VerticalAlignment="Center"
                                                Background="{x:Bind SpeakerBrush, Mode=OneWay}"
                                                CornerRadius="6" />
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{x:Bind SpeakerLabel, Mode=OneWay}" />
                                        <ComboBox Width="220"
                                                  ItemsSource="{x:Bind SpeakerOptions, Mode=OneWay}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="SpeakerId"
                                                  SelectedValue="{x:Bind SelectedSpeakerId, Mode=TwoWay}" />
                                        <Button Content="Apply Speaker"
                                                Click="AssignSpeakerButton_Click"
                                                Tag="{x:Bind}" />
                                    </StackPanel>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="Transcript" />
                                            <TextBox AcceptsReturn="True"
                                                     MinHeight="64"
                                                     Text="{x:Bind Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind TranslationLabel, Mode=OneWay}" />
                                            <TextBlock Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                       Text="{x:Bind TranslationStatusLabel, Mode=OneWay}"
                                                       TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       Text="{x:Bind TtsStatusLabel, Mode=OneWay}"
                                                       TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                       Text="{x:Bind TtsWarningLabel, Mode=OneWay}"
                                                       TextWrapping="WrapWholeWords" />
                                            <TextBox AcceptsReturn="True"
                                                     MinHeight="64"
                                                     Text="{x:Bind TranslationText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock VerticalAlignment="Center" Text="Start" />
                                        <NumberBox Width="120" SmallChange="0.1" Value="{x:Bind StartSeconds, Mode=TwoWay}" />
                                        <TextBlock VerticalAlignment="Center" Text="End" />
                                        <NumberBox Width="120" SmallChange="0.1" Value="{x:Bind EndSeconds, Mode=TwoWay}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <!--
            Row 1, Col 1: Settings / info panel.
            Sits in the same * row as the left panel, so it gets a bounded height from
            the window and its internal ScrollViewer can scroll without inflating the row.
        -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Workspace" />
                        <TextBlock Text="{x:Bind ViewModel.ProjectRootPath, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock FontWeight="SemiBold" Margin="0,8,0,0" Text="Media" />
                        <TextBlock Text="{x:Bind ViewModel.MediaPath, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock FontWeight="SemiBold" Margin="0,8,0,0" Text="Source" />
                        <TextBlock Text="{x:Bind ViewModel.SourceStatus, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Stages" />
                        <TextBlock Text="{x:Bind ViewModel.VadStageStatus, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.AsrStageStatus, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.DiarizationStageStatus, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.TranslationStageStatus, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.TtsStageStatus, Mode=OneWay}" />
                        <TextBlock Margin="0,8,0,0" Text="{x:Bind ViewModel.TranscriptRevisionLabel, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock Text="{x:Bind ViewModel.TranslationRevisionLabel, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock Text="{x:Bind ViewModel.TranslationRefreshStatus, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Speakers" />
                        <ListView x:Name="SpeakersListView"
                                  Height="320"
                                  ItemsSource="{x:Bind ViewModel.Speakers, Mode=OneWay}"
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:SpeakerItem">
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <StackPanel Spacing="8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Width="12"
                                                        Height="12"
                                                        VerticalAlignment="Center"
                                                        Background="{x:Bind AccentBrush, Mode=OneWay}"
                                                        CornerRadius="6" />
                                                <TextBox Width="180"
                                                         Text="{x:Bind DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Content="Rename"
                                                        Click="RenameSpeakerButton_Click"
                                                        Tag="{x:Bind}" />
                                                <ComboBox Width="160"
                                                          ItemsSource="{x:Bind MergeTargets, Mode=OneWay}"
                                                          DisplayMemberPath="DisplayName"
                                                          SelectedValuePath="SpeakerId"
                                                          SelectedValue="{x:Bind MergeTargetSpeakerId, Mode=TwoWay}" />
                                                <Button Content="Merge"
                                                        Click="MergeSpeakerButton_Click"
                                                        Tag="{x:Bind}" />
                                                <Button Content="Extract Reference"
                                                        Click="ExtractReferenceClipButton_Click"
                                                        Tag="{x:Bind}" />
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind TurnSummary, Mode=OneWay}" />
                                            <TextBlock Text="{x:Bind ReferenceClipStatus, Mode=OneWay}" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ComboBox Width="220"
                                                          PlaceholderText="Kokoro voice"
                                                          ItemsSource="{x:Bind VoiceOptions, Mode=OneWay}"
                                                          DisplayMemberPath="DisplayLabel"
                                                          SelectedValuePath="VoiceId"
                                                          SelectedValue="{x:Bind SelectedVoiceId, Mode=TwoWay}" />
                                                <Button Content="Assign Voice"
                                                        Click="AssignVoiceButton_Click"
                                                        Tag="{x:Bind}" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="Generate TTS"
                                                        Click="GenerateTtsButton_Click"
                                                        Tag="{x:Bind}" />
                                                <Button Content="Regenerate Stale"
                                                        Click="RegenerateStaleTtsButton_Click"
                                                        Tag="{x:Bind}"
                                                        IsEnabled="{x:Bind HasStaleTts, Mode=OneWay}" />
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind VoiceAssignmentStatus, Mode=OneWay}" />
                                            <TextBlock Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                       Text="{x:Bind VoiceWarning, Mode=OneWay}"
                                                       TextWrapping="WrapWholeWords" />
                                            <ListView ItemsSource="{x:Bind Turns, Mode=OneWay}"
                                                      SelectionMode="None"
                                                      MaxHeight="180">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="viewModels:SpeakerTurnItem">
                                                        <StackPanel Margin="0,0,0,6" Spacing="4">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <TextBlock VerticalAlignment="Center"
                                                                           Text="{x:Bind DisplayTimeRange, Mode=OneWay}" />
                                                                <Button Content="Jump"
                                                                        Click="JumpToSpeakerTurnButton_Click"
                                                                        Tag="{x:Bind}" />
                                                                <Button Content="Split at Cursor"
                                                                        Click="SplitSpeakerTurnButton_Click"
                                                                        Tag="{x:Bind}" />
                                                            </StackPanel>
                                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                       Text="{x:Bind ConfidenceLabel, Mode=OneWay}" />
                                                            <TextBlock Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                                       Text="{x:Bind OverlapLabel, Mode=OneWay}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Defaults" />
                        <TextBlock Text="Default source language" />
                        <ComboBox Width="180"
                                  ItemsSource="{x:Bind ViewModel.TranscriptLanguageOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Code"
                                  SelectedValue="{x:Bind ViewModel.DefaultSourceLanguageCode, Mode=TwoWay}" />
                        <TextBlock Text="Default target language" />
                        <ComboBox Width="180"
                                  ItemsSource="{x:Bind ViewModel.TranslationLanguageOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Code"
                                  SelectedValue="{x:Bind ViewModel.DefaultTargetLanguageCode, Mode=TwoWay}" />
                        <TextBlock Text="Model tier" />
                        <ComboBox Width="180"
                                  ItemsSource="{x:Bind ViewModel.ModelTierOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Key"
                                  SelectedValue="{x:Bind ViewModel.SelectedModelTier, Mode=TwoWay}" />
                        <CheckBox Content="Commercial-safe mode"
                                  IsChecked="{x:Bind ViewModel.CommercialSafeMode, Mode=TwoWay}" />
                        <TextBlock Text="{x:Bind ViewModel.WindowLayoutSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Recent Projects" />
                        <ListView x:Name="RecentProjectsListView"
                                  Height="240"
                                  IsItemClickEnabled="True"
                                  ItemsSource="{x:Bind ViewModel.RecentProjects, Mode=OneWay}"
                                  ItemClick="RecentProjectsListView_ItemClick">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:RecentProjectItem">
                                    <StackPanel Padding="0,4">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ProjectName}" />
                                        <TextBlock Text="{x:Bind ProjectPath}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Opacity="0.7" Text="{x:Bind LastOpenedLabel}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="Status" />
                            <Button Content="Copy Error"
                                    Click="CopyErrorButton_Click"
                                    IsEnabled="{x:Bind ViewModel.CanCopyError, Mode=OneWay}" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
