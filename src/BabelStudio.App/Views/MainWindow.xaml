<Window
    x:Class="BabelStudio.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:BabelStudio.App.ViewModels"
    mc:Ignorable="d"
    Title="Babel Studio">

    <Grid Padding="20" RowSpacing="16" ColumnSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="420" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12">
            <Button Content="Open Media" Click="OpenMediaButton_Click" />
            <Button Content="Open Project" Click="OpenProjectButton_Click" />
            <Button Content="Save Transcript" Click="SaveTranscriptButton_Click" IsEnabled="{x:Bind ViewModel.CanSaveTranscript, Mode=OneWay}" />
            <Button Content="{x:Bind ViewModel.TranslateButtonText, Mode=OneWay}"
                    Click="TranslateButton_Click"
                    IsEnabled="{x:Bind ViewModel.CanTranslate, Mode=OneWay}" />
            <Button Content="Save Translation"
                    Click="SaveTranslationButton_Click"
                    IsEnabled="{x:Bind ViewModel.CanSaveTranslation, Mode=OneWay}" />
            <Button Content="Merge Selected" Click="MergeSegmentsButton_Click" />
            <Button Content="Save Settings" Click="SaveSettingsButton_Click" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="12">
                <Grid>
                    <MediaPlayerElement x:Name="SourcePlayerElement"
                                        AreTransportControlsEnabled="False"
                                        Height="320" />
                    <Border VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20"
                            Padding="16,8"
                            Background="#90000000"
                            CornerRadius="8">
                        <TextBlock FontSize="20"
                                   Foreground="White"
                                   Text="{x:Bind ViewModel.CurrentSubtitleText, Mode=OneWay}"
                                   TextAlignment="Center"
                                   TextWrapping="WrapWholeWords" />
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
                <Button Content="Play" Click="PlayButton_Click" IsEnabled="{x:Bind ViewModel.CanPlayMedia, Mode=OneWay}" />
                <Button Content="Pause" Click="PauseButton_Click" IsEnabled="{x:Bind ViewModel.CanPlayMedia, Mode=OneWay}" />
                <Button Content="Jump to Active" Click="JumpToActiveSegmentButton_Click" />
                <TextBlock VerticalAlignment="Center" Text="{x:Bind ViewModel.PlaybackPositionText, Mode=OneWay}" />
                <TextBlock VerticalAlignment="Center" Text="Speed" />
                <ComboBox x:Name="PlaybackSpeedComboBox"
                          Width="100"
                          ItemsSource="{x:Bind ViewModel.PlaybackSpeedOptions, Mode=OneWay}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Rate"
                          SelectedIndex="1"
                          SelectionChanged="PlaybackSpeedComboBox_SelectionChanged" />
                <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" Text="{x:Bind ViewModel.PlaybackBackendLabel, Mode=OneWay}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="6">
                <TextBlock Foreground="{ThemeResource SystemFillColorCautionBrush}"
                           Text="{x:Bind ViewModel.PlaybackWarning, Mode=OneWay}"
                           TextWrapping="WrapWholeWords" />
                <canvas:CanvasControl x:Name="WaveformCanvas"
                                      Height="96"
                                      Draw="WaveformCanvas_Draw"
                                      PointerPressed="WaveformCanvas_PointerPressed" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Workspace" />
                        <TextBlock Text="{x:Bind ViewModel.ProjectRootPath, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock FontWeight="SemiBold" Margin="0,8,0,0" Text="Media" />
                        <TextBlock Text="{x:Bind ViewModel.MediaPath, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock FontWeight="SemiBold" Margin="0,8,0,0" Text="Source" />
                        <TextBlock Text="{x:Bind ViewModel.SourceStatus, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Stages" />
                        <TextBlock Text="{x:Bind ViewModel.VadStageStatus, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.AsrStageStatus, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.TranslationStageStatus, Mode=OneWay}" />
                        <TextBlock Margin="0,8,0,0" Text="{x:Bind ViewModel.TranscriptRevisionLabel, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock Text="{x:Bind ViewModel.TranslationRevisionLabel, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock Text="{x:Bind ViewModel.TranslationRefreshStatus, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Defaults" />
                        <TextBlock Text="Default source language" />
                        <ComboBox Width="180"
                                  ItemsSource="{x:Bind ViewModel.TranscriptLanguageOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Code"
                                  SelectedValue="{x:Bind ViewModel.DefaultSourceLanguageCode, Mode=TwoWay}" />
                        <TextBlock Text="Default target language" />
                        <ComboBox Width="180"
                                  ItemsSource="{x:Bind ViewModel.TranscriptLanguageOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Code"
                                  SelectedValue="{x:Bind ViewModel.DefaultTargetLanguageCode, Mode=TwoWay}" />
                        <TextBlock Text="Model tier" />
                        <ComboBox Width="180"
                                  ItemsSource="{x:Bind ViewModel.ModelTierOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Key"
                                  SelectedValue="{x:Bind ViewModel.SelectedModelTier, Mode=TwoWay}" />
                        <CheckBox Content="Commercial-safe mode"
                                  IsChecked="{x:Bind ViewModel.CommercialSafeMode, Mode=TwoWay}" />
                        <TextBlock Text="{x:Bind ViewModel.WindowLayoutSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Recent Projects" />
                        <ListView x:Name="RecentProjectsListView"
                                  Height="240"
                                  IsItemClickEnabled="True"
                                  ItemsSource="{x:Bind ViewModel.RecentProjects, Mode=OneWay}"
                                  ItemClick="RecentProjectsListView_ItemClick">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:RecentProjectItem">
                                    <StackPanel Padding="0,4">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ProjectName}" />
                                        <TextBlock Text="{x:Bind ProjectPath}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Opacity="0.7" Text="{x:Bind LastOpenedLabel}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="Status" />
                            <Button Content="Copy Error"
                                    Click="CopyErrorButton_Click"
                                    IsEnabled="{x:Bind ViewModel.CanCopyError, Mode=OneWay}" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="12">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center" Text="Project Name" />
                <TextBox Grid.Column="1"
                         MinWidth="280"
                         Text="{x:Bind ViewModel.ProjectNameDraft, Mode=TwoWay}" />
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Transcript Language" />
                <ComboBox Grid.Column="3"
                          PlaceholderText="Choose language"
                          ItemsSource="{x:Bind ViewModel.TranscriptLanguageOptions, Mode=OneWay}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Code"
                          SelectedValue="{x:Bind ViewModel.SelectedTranscriptLanguageCode, Mode=TwoWay}"
                          SelectionChanged="TranscriptLanguageComboBox_SelectionChanged" />
            </Grid>

            <ListView x:Name="SegmentsListView"
                      IsItemClickEnabled="True"
                      ItemClick="SegmentsListView_ItemClick"
                      ItemsSource="{x:Bind ViewModel.Segments, Mode=OneWay}"
                      SelectionMode="Multiple">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:TranscriptSegmentItem">
                        <Border Margin="0,0,0,8"
                                Padding="10"
                                Background="{x:Bind BackgroundBrush, Mode=OneWay}"
                                CornerRadius="8">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock VerticalAlignment="Center" Text="{x:Bind DisplayTimeRange}" />
                                    <Button Content="Jump" Click="JumpToSegmentButton_Click" Tag="{x:Bind}" />
                                    <Button Content="Split at Cursor" Click="SplitSegmentButton_Click" Tag="{x:Bind}" />
                                    <Button Content="Trim" Click="TrimSegmentButton_Click" Tag="{x:Bind}" />
                                </StackPanel>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="Transcript" />
                                        <TextBox AcceptsReturn="True"
                                                 MinHeight="64"
                                                 Text="{x:Bind Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind TranslationLabel, Mode=OneWay}" />
                                        <TextBox AcceptsReturn="True"
                                                 MinHeight="64"
                                                 Text="{x:Bind TranslationText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock VerticalAlignment="Center" Text="Start" />
                                    <NumberBox Width="120" SmallChange="0.1" Value="{x:Bind StartSeconds, Mode=TwoWay}" />
                                    <TextBlock VerticalAlignment="Center" Text="End" />
                                    <NumberBox Width="120" SmallChange="0.1" Value="{x:Bind EndSeconds, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Window>
