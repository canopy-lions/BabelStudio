<Window
    x:Class="BabelStudio.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:BabelStudio.App.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:BabelStudio.App.ViewModels"
    mc:Ignorable="d"
    Title="Babel Studio">

    <Grid RowSpacing="16" Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="Open Media" Click="OpenMediaButton_Click" />
            <Button Content="Open Project" Click="OpenProjectButton_Click" />
            <Button Content="Save Transcript" Click="SaveTranscriptButton_Click" IsEnabled="{x:Bind ViewModel.CanSaveTranscript, Mode=OneWay}" />
            <Button Content="{x:Bind ViewModel.TranslateButtonText, Mode=OneWay}"
                    Click="TranslateButton_Click"
                    IsEnabled="{x:Bind ViewModel.CanTranslate, Mode=OneWay}" />
            <Button Content="Save Translation"
                    Click="SaveTranslationButton_Click"
                    IsEnabled="{x:Bind ViewModel.CanSaveTranslation, Mode=OneWay}" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center" Text="Project Name" />
            <TextBox Grid.Column="1"
                     MinWidth="280"
                     Text="{x:Bind ViewModel.ProjectNameDraft, Mode=TwoWay}" />
            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Transcript Language" />
            <ComboBox Grid.Column="3"
                      PlaceholderText="Choose language"
                      ItemsSource="{x:Bind ViewModel.TranscriptLanguageOptions, Mode=OneWay}"
                      DisplayMemberPath="DisplayName"
                      SelectedValuePath="Code"
                      SelectedValue="{x:Bind ViewModel.SelectedTranscriptLanguageCode, Mode=TwoWay}"
                      SelectionChanged="TranscriptLanguageComboBox_SelectionChanged" />
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="Source" />
                    <TextBlock Text="{x:Bind ViewModel.SourceStatus, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="VAD / ASR" />
                    <TextBlock Text="{x:Bind ViewModel.VadStageStatus, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind ViewModel.AsrStageStatus, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="Transcript" />
                    <TextBlock Text="{x:Bind ViewModel.TranscriptRevisionLabel, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="Translation" />
                    <TextBlock Text="{x:Bind ViewModel.TranslationStageStatus, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{x:Bind ViewModel.TranslationRevisionLabel, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{x:Bind ViewModel.TranslationRefreshStatus, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="3" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListView ItemsSource="{x:Bind ViewModel.Segments, Mode=OneWay}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:TranscriptSegmentItem">
                        <Border Padding="8">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock VerticalAlignment="Top" Text="{x:Bind DisplayTimeRange}" />
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="Transcript" />
                                    <TextBox AcceptsReturn="True"
                                             MinHeight="64"
                                             Text="{x:Bind Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" />
                                    <TextBlock FontWeight="SemiBold" Text="Spanish Draft" />
                                    <TextBox AcceptsReturn="True"
                                             MinHeight="64"
                                             Text="{x:Bind TranslationText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Column="1" Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="Workspace" />
                <TextBlock Text="{x:Bind ViewModel.ProjectRootPath, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                <TextBlock FontWeight="SemiBold" Margin="0,12,0,0" Text="Media" />
                <TextBlock Text="{x:Bind ViewModel.MediaPath, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                <TextBlock FontWeight="SemiBold" Margin="0,12,0,0" Text="Transcript Language" />
                <TextBlock Text="{x:Bind ViewModel.TranscriptLanguageSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                    <TextBlock FontWeight="SemiBold" Text="Status" />
                    <Button Content="Copy Error"
                            Click="CopyErrorButton_Click"
                            IsEnabled="{x:Bind ViewModel.CanCopyError, Mode=OneWay}" />
                </StackPanel>
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
